{
  "name": "@splicelabs/mechanic",
  "version": "0.1.0",
  "description": "Skill registry and scope manager for Claude Code. Register skills once, toggle them per scope.",
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "cli",
    "registry"
  ],
  "homepage": "https://github.com/SpliceLabs/mechanic#readme",
  "bugs": {
    "url": "https://github.com/SpliceLabs/mechanic/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpliceLabs/mechanic.git"
  },
  "license": "MIT",
  "author": "Splice Labs",
  "type": "module",
  "bin": {
    "mechanic": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').cpSync('src/skills','dist/skills',{recursive:true,force:true,filter:(s)=>!/(^|[\\\\/])evals([\\\\/]|$)/.test(s)})\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
